    given-names: Kaleem
    email: kaleemmehmood73@gmail.com
    affiliation: "Beijing Forestry University; Institute of Forest Science, University of Swat"
keywords:
  - vegetation greening
  - MODIS NDVI
  - ERA5-Land
  - Mann-Kendall
  - Theil-Sen
  - wavelet coherence
  - southern China
  - remote sensing
